# MAJER Monorepo — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# All variables must be set before running docker compose up -d.

# ─────────────────────────────────────────────
# DOMAIN
# ─────────────────────────────────────────────
# Today: nova-tive.com (Cloudflare, DNS → VPS-IP)
# Target: digitale-bildung.de (buy separately, then update this)
DOMAIN=digitale-bildung.de

# ─────────────────────────────────────────────
# POCKETBASE
# ─────────────────────────────────────────────
# Internal URL used by Next.js apps (within Docker network)
POCKETBASE_URL=http://pocketbase:8090

# PocketBase superuser email (used for initial setup only)
POCKETBASE_ADMIN_EMAIL=admin@digitale-bildung.de

# PocketBase superuser password (min 10 chars, use a password manager)
POCKETBASE_ADMIN_PASSWORD=

# ─────────────────────────────────────────────
# N8N
# ─────────────────────────────────────────────
# Shared secret between n8n and the Next.js apps (arbitrary random string)
# Generate: openssl rand -hex 32
N8N_WEBHOOK_SECRET=

# n8n basic auth for the UI (format: user:password)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# Encryption key for n8n credentials (generate: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# External URL for n8n webhooks (must match Traefik routing)
N8N_WEBHOOK_URL=https://n8n.${DOMAIN}

# ─────────────────────────────────────────────
# TRAEFIK
# ─────────────────────────────────────────────
# Dashboard basic auth (generate: htpasswd -nb user password | sed -e s/\\$/\\$\\$/g)
TRAEFIK_DASHBOARD_AUTH=

# Let's Encrypt email (for SSL certificate notifications)
LETSENCRYPT_EMAIL=heinrichmajer2005@gmail.com

# ─────────────────────────────────────────────
# CLOUDFLARE
# ─────────────────────────────────────────────
# Scoped API token: Zone → DNS → Edit (for the DOMAIN zone only)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Zone ID for the domain (find in Cloudflare Dashboard → Overview)
CLOUDFLARE_ZONE_ID=

# ─────────────────────────────────────────────
# POSTGRES (for n8n)
# ─────────────────────────────────────────────
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=

# ─────────────────────────────────────────────
# VEREIN APP
# ─────────────────────────────────────────────
# Next.js public base URL (used for absolute links, OG tags)
NEXT_PUBLIC_VEREIN_URL=https://verein.${DOMAIN}

# ─────────────────────────────────────────────
# NOVA APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_NOVA_URL=https://nova.${DOMAIN}
